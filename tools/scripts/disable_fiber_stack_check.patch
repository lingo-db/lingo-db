diff -uNr a/Python/ceval.c b/Python/ceval.c
--- a/Python/ceval.c	2025-10-07 11:34:52.000000000 +0200
+++ b/Python/ceval.c	2025-11-24 13:51:46.605469485 +0100
@@ -429,51 +429,35 @@
 _Py_InitializeRecursionLimits(PyThreadState *tstate)
 {
     _PyThreadStateImpl *_tstate = (_PyThreadStateImpl *)tstate;
-#ifdef WIN32
-    ULONG_PTR low, high;
-    GetCurrentThreadStackLimits(&low, &high);
-    _tstate->c_stack_top = (uintptr_t)high;
-    ULONG guarantee = 0;
-    SetThreadStackGuarantee(&guarantee);
-    _tstate->c_stack_hard_limit = ((uintptr_t)low) + guarantee + _PyOS_STACK_MARGIN_BYTES;
-    _tstate->c_stack_soft_limit = _tstate->c_stack_hard_limit + _PyOS_STACK_MARGIN_BYTES;
-#else
+
+    /* We *don't* query the OS for the thread's stack here, because that
+       doesn't work with fibers (e.g. boost::fibers). Instead, we set
+       artificial limits that effectively disable CPython's C stack
+       overflow detection: the check in _Py_CheckStackLimit will always
+       say "there is plenty of space". */
+
     uintptr_t here_addr = _Py_get_machine_stack_pointer();
-/// XXX musl supports HAVE_PTHRED_GETATTR_NP, but the resulting stack size
-/// (on alpine at least) is much smaller than expected and imposes undue limits
-/// compared to the old stack size estimation.  (We assume musl is not glibc.)
-#  if defined(HAVE_PTHREAD_GETATTR_NP) && !defined(_AIX) && \
-        !defined(__NetBSD__) && (defined(__GLIBC__) || !defined(__linux__))
-    size_t stack_size, guard_size;
-    void *stack_addr;
-    pthread_attr_t attr;
-    int err = pthread_getattr_np(pthread_self(), &attr);
-    if (err == 0) {
-        err = pthread_attr_getguardsize(&attr, &guard_size);
-        err |= pthread_attr_getstack(&attr, &stack_addr, &stack_size);
-        err |= pthread_attr_destroy(&attr);
-    }
-    if (err == 0) {
-        uintptr_t base = ((uintptr_t)stack_addr) + guard_size;
-        _tstate->c_stack_top = base + stack_size;
-#ifdef _Py_THREAD_SANITIZER
-        // Thread sanitizer crashes if we use a bit more than half the stack.
-        _tstate->c_stack_soft_limit = base + (stack_size / 2);
-#else
-        _tstate->c_stack_soft_limit = base + _PyOS_STACK_MARGIN_BYTES * 2;
-#endif
-        _tstate->c_stack_hard_limit = base + _PyOS_STACK_MARGIN_BYTES;
-        assert(_tstate->c_stack_soft_limit < here_addr);
-        assert(here_addr < _tstate->c_stack_top);
-        return;
-    }
-#  endif
-    _tstate->c_stack_top = _Py_SIZE_ROUND_UP(here_addr, 4096);
-    _tstate->c_stack_soft_limit = _tstate->c_stack_top - Py_C_STACK_SIZE;
-    _tstate->c_stack_hard_limit = _tstate->c_stack_top - (Py_C_STACK_SIZE + _PyOS_STACK_MARGIN_BYTES);
+
+    /* Fake "top" of the stack: max uintptr_t */
+    _tstate->c_stack_top = (uintptr_t)-1;
+
+    /* Fake soft/hard limits near address 0.
+       For a normal process address space, here_addr will be >> 0, so
+       here_addr > soft_limit + margin*_PyOS_STACK_MARGIN_BYTES will
+       always be true and the check will always succeed. */
+    _tstate->c_stack_soft_limit = (uintptr_t)0;
+    _tstate->c_stack_hard_limit = (uintptr_t)1;  /* must be non-zero
+                                                    so we never re-init */
+
+#ifdef Py_DEBUG
+    /* Keep the same invariants the original code asserts. These will hold
+       for any realistic here_addr in a normal process. */
+    assert(_tstate->c_stack_soft_limit < here_addr);
+    assert(here_addr < _tstate->c_stack_top);
 #endif
 }
 
+
 /* The function _Py_EnterRecursiveCallTstate() only calls _Py_CheckRecursiveCall()
    if the recursion_depth reaches recursion_limit. */
 int
