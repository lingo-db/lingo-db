CREATE FUNCTION addInt(a int, b int)
RETURNS int
AS $$
    return a+b
$$ LANGUAGE python

statement ok
CREATE OR REPLACE FUNCTION calculateFac(b float8)
RETURNS float8
AS $$
def calculatefac(b):
    for i in range(1, int(b)):
        b = b * i
    return b
$$ LANGUAGE python;

query 9
select calculatefac(10.0::float8);
----
3628800