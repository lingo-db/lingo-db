CREATE OR REPLACE FUNCTION domain_from_str(text_input TEXT)
RETURNS TEXT
AS $$
import hipy
from hipy.lib.urllib.parse import urlparse

@hipy.compiled_function
def domain_from_str(string):
    return urlparse(string).netloc

$$ LANGUAGE hipy;

query tsv rowsort 3
SELECT levenshtein_dist('kitten'::text, 'sitting'::text);
----
3

query tsv rowsort 4
select domain_from_str('http://docs.python.org:80/3/library/urllib.parse.html?highlight=params#url-parsing'::text) as type1;
----
docs.python.org:80

query tsv rowsort 5
select check_iban('DE89370400440532013001'::text) as type1;
