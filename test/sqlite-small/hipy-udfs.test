CREATE OR REPLACE FUNCTION reverse_str(text_input TEXT)
RETURNS TEXT
AS $$
import hipy
from hipy.lib.urllib.parse import urlparse

@hipy.compiled_function
def reverse_str(string):
    res = ""
    for x in string:
        res = x + res
    return res
$$ LANGUAGE hipy;

query tsv rowsort 2
select reverse_str('abcdefg'::text) as reversed
----
gfedcba


