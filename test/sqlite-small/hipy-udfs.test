CREATE OR REPLACE FUNCTION check_iban (text_input TEXT)
RETURNS bool
AS $$
import hipy
@hipy.compiled_function
def check_iban(iban):
    iban = iban.replace(" ", "").replace("-", "").replace(".", "")
    iban = iban.upper()
    iban = iban[4:] + iban[:4]
    r = 0
    for c in iban:
        if c.isdigit():
            c = int(c)
            r *= 10
        else:
            c = ord(c) - ord("A") + 10
            r *= 100
        r += c
        r %= 97
    return r % 97 == 1
$$ LANGUAGE hipy;

