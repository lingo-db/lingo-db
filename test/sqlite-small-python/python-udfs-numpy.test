CREATE TABLE ints(i int not null);

statement ok
INSERT INTO ints VALUES (1), (2), (3), (4);

# numpy import + simple use through a UDF.
# PYTHONPATH=/site-packages is set by the wasix shim, so no sys.path hack
# needed.
statement ok
CREATE OR REPLACE FUNCTION np_sum_seq(x int)
RETURNS int
AS $$
import numpy as np
def np_sum_seq(x):
    # int() cast so the int wasm export receives a 4-byte i32, not a numpy scalar.
    return int(np.arange(1, x + 1, dtype=np.int64).sum())
$$ LANGUAGE python;

query np-1
SELECT np_sum_seq(10);
----
55

query np-2
SELECT np_sum_seq(i) FROM ints ORDER BY i;
----
1
3
6
10

# Double dispatch: matrix op.
statement ok
CREATE OR REPLACE FUNCTION np_mat_diag(n int)
RETURNS int
AS $$
import numpy as np
def np_mat_diag(n):
    return int(np.eye(n, dtype=np.int64).trace())
$$ LANGUAGE python;

query np-3
SELECT np_mat_diag(5);
----
5
