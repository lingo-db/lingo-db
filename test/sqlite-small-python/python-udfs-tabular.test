# pandas roundtrip (numeric columns): to_pandas then back via pyarrow
statement ok
CREATE OR REPLACE FUNCTION py_pandas_passthrough(t TABLE(id int, score float8))
RETURNS TABLE(id int, score float8)
AS $$
import pyarrow as pa
def py_pandas_passthrough(t):
    df = t.to_pandas()
    return pa.Table.from_pandas(df, preserve_index=False)
$$ LANGUAGE python;

