# pandas-side compute: square the score column
statement ok
CREATE OR REPLACE FUNCTION py_square_score(t TABLE(id int, score float8))
RETURNS TABLE(id int, score float8)
AS $$
import pyarrow as pa
def py_square_score(t):
    df = t.to_pandas()
    df["score"] = df["score"] * df["score"]
    return pa.Table.from_pandas(df, preserve_index=False)
$$ LANGUAGE python;

