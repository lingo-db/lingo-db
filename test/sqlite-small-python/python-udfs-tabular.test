# pandas-side filter: keep rows with score > 2.0; row count drops
statement ok
CREATE OR REPLACE FUNCTION py_pandas_filter(t TABLE(id int, score float8))
RETURNS TABLE(id int, score float8)
AS $$
import pyarrow as pa
def py_pandas_filter(t):
    df = t.to_pandas()
    return pa.Table.from_pandas(df[df["score"] > 2.0], preserve_index=False)
$$ LANGUAGE python;

