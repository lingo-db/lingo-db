# identity (pass-through using pyarrow only)
statement ok
CREATE OR REPLACE FUNCTION py_identity()
RETURNS TABLE(id int, score float8)
AS $$
def py_identity(t):
    return t
$$ LANGUAGE python;

query py-tab-1 nosort
SELECT id, score FROM py_identity((SELECT id, score FROM rows)) ORDER BY id;
----
1
0.5
2
1.5
3
2.5
4
3.5
5
4.5

# pandas roundtrip (numeric columns): to_pandas then back via pyarrow
statement ok
CREATE OR REPLACE FUNCTION py_pandas_passthrough()
RETURNS TABLE(id int, score float8)
AS $$
import pyarrow as pa
def py_pandas_passthrough(t):
    df = t.to_pandas()
    return pa.Table.from_pandas(df, preserve_index=False)
$$ LANGUAGE python;

query py-tab-2 nosort
SELECT id, score FROM py_pandas_passthrough((SELECT id, score FROM rows)) ORDER BY id;
----
1
0.5
2
1.5
3
2.5
4
3.5
5
4.5

# pandas-side compute: square the score column
statement ok
CREATE OR REPLACE FUNCTION py_square_score()
RETURNS TABLE(id int, score float8)
AS $$
import pyarrow as pa
def py_square_score(t):
    df = t.to_pandas()
    df["score"] = df["score"] * df["score"]
    return pa.Table.from_pandas(df, preserve_index=False)
$$ LANGUAGE python;

query py-tab-3 nosort
SELECT id, score FROM py_square_score((SELECT id, score FROM rows)) ORDER BY id;
----
1
0.25
2
2.25
3
6.25
4
12.25
5
20.25

# pandas-side filter: keep rows with score > 2.0; row count drops
statement ok
CREATE OR REPLACE FUNCTION py_pandas_filter()
RETURNS TABLE(id int, score float8)
AS $$
import pyarrow as pa
def py_pandas_filter(t):
    df = t.to_pandas()
    return pa.Table.from_pandas(df[df["score"] > 2.0], preserve_index=False)
$$ LANGUAGE python;

query py-tab-4 nosort
SELECT id, score FROM py_pandas_filter((SELECT id, score FROM rows)) ORDER BY id;
----
3
2.5
4
3.5
5
4.5

query py-tab-4-count
SELECT count(*) FROM py_pandas_filter((SELECT id, score FROM rows));
----
3

# varchar passthrough — exercises arrow varlen32 (no pandas involved; pandas
# round-trip of string columns currently mangles output and is a known issue
# in the runtime varchar reader, separate from the tabular UDF wiring).
statement ok
CREATE OR REPLACE FUNCTION py_str_id()
RETURNS TABLE(id int, w varchar)
AS $$
def py_str_id(t):
    return t
$$ LANGUAGE python;

